# URL of the deployed FastAPI Backend on Render
VITE_API_URL=https://readpulse.onrender.com/api/v1

# Application Name
VITE_APP_NAME=PROBEXR

# Minimum word count to trigger summarization
VITE_SUMMARIZE_MIN_WORDS=30
