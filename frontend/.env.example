# ReadPulse Frontend — Environment Variables
# Copy to .env or .env.local and configure if you are not using default ports.

# URL of the FastAPI Backend
VITE_API_URL=http://localhost:8000

# Application Name (displayed in title and headers)
VITE_APP_NAME=ReadPulse

# Minimum word count required to trigger backend summarization
VITE_SUMMARIZE_MIN_WORDS=30
