# PROBEXR Backend — Environment Variables
# Copy to .env and fill in required values.

# ── App ──────────────────────────────────────────────────────
APP_NAME=PROBEXR
ENVIRONMENT=development
DEBUG=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./app.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/probexr

# Connection pool (PostgreSQL only)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Redis (rate limiting & lockouts) ────────────────────────
# Optional in development — falls back to in-memory limiter
REDIS_URL=redis://localhost:6379/0

# ── Rate Limits (per minute) ────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LLM_PER_MINUTE=10
RATE_LIMIT_AUTH_PER_MINUTE=5

# ── Account Lockout ──────────────────────────────────────────
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_SECONDS=900

# ── Auth / JWT ───────────────────────────────────────────────
SECRET_KEY=dev-secret-change-this
ALGORITHM=HS256
# RS256/ES256 optional keys (multi-line strings supported)
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Token Lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Provider (pick one) ──────────────────────────────────
# GROQ_API_KEY=your-groq-key
# OPENAI_API_KEY=your-openai-key
# OPENROUTER_API_KEY=your-openrouter-key

# ── Summarization ────────────────────────────────────────────
# SUMMARIZE_PROVIDER=groq
# SUMMARIZE_MODEL=llama-3.3-70b-versatile
SUMMARIZE_TIMEOUT_SECONDS=90
MIN_WORDS=30
TARGET_MIN_WORDS=80
TARGET_MAX_WORDS=300
SUMMARIZE_MAX_WORDS=10000

# ── OAuth2 (Google / GitHub) ─────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP ─────────────────────────────────────────────
# Set these to enable Magic Links and Password Resets
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@probexr.com

# ── Feature Flags ────────────────────────────────────────────
TTS_ENABLED=false
