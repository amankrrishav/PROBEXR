# Optional: set one API key for human-like summaries. If none set, backend uses free extractive mode ($0).
# Groq (free, no credit card): https://console.groq.com/keys

# Groq (free tier)
GROQ_API_KEY=

# Or OpenAI
# OPENAI_API_KEY=

# Or OpenRouter (free models available)
# OPENROUTER_API_KEY=

# Optional overrides
# SUMMARIZE_MODEL=llama-3.3-70b-versatile
# SUMMARIZE_TIMEOUT=90
# CORS_ORIGINS=*

# For production, set a long random string as the secret key. This is used to sign cookies and should be kept secret.
SECRET_KEY=b872ca7de2823569800478fd9146f17af0b6c3300f35483854512294d97b5100

# JWT signing algorithm for access tokens (default HS256)
JWT_ALGORITHM=HS256