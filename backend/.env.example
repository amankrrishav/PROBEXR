# ReadPulse Backend — Environment Variables
# Copy to .env and fill in required values.

# App
APP_NAME=ReadPulse
ENVIRONMENT=development
DEBUG=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Database
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./readpulse.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/readpulse

# Connection pool (PostgreSQL only)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis (rate limiting)
# Optional in development — falls back to in-memory limiter
REDIS_URL=redis://localhost:6379/0

# Rate Limits (per minute)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LLM_PER_MINUTE=10

# Auth
SECRET_KEY=dev-secret-change-this
JWT_ALGORITHM=HS256

# LLM Provider (pick one — Groq free tier recommended for dev)
# GROQ_API_KEY=your-groq-key
# OPENAI_API_KEY=your-openai-key
# OPENROUTER_API_KEY=your-openrouter-key

# Summarization
# SUMMARIZE_MODEL=llama-3.3-70b-versatile
SUMMARIZE_TIMEOUT=90
SUMMARIZE_MIN_WORDS=30
SUMMARIZE_TARGET_MIN_WORDS=80
SUMMARIZE_TARGET_MAX_WORDS=300
