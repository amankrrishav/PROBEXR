# Optional: set one API key for human-like summaries. If none set, backend uses free extractive mode ($0).
# Groq (free, no credit card): https://console.groq.com/keys

# Groq (free tier)
GROQ_API_KEY=

# Or OpenAI
# OPENAI_API_KEY=

# Or OpenRouter (free models available)
# OPENROUTER_API_KEY=

# Optional overrides
# SUMMARIZE_MODEL=llama-3.3-70b-versatile
# SUMMARIZE_TIMEOUT=90
# CORS_ORIGINS=*
